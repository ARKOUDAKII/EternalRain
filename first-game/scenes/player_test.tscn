[sub_resource type="GDScript" id="GDScript_fdpfy"]
script/source = "extends CharacterBody2D

#CONSTANTS
var SPEED = 150
var ROTATION_SPEED = 5
var DASH_SPEED = 400
var DASH_DURATION = 0.25

#GLOBAL VARIABLES
var rotation_direction = 1
var move_en = 1
var dash_en = 0
var dash_direction = 1

func get_input():
	if dash_en:
		velocity.x = dash_direction * DASH_SPEED
	elif move_en:
		var direction = Input.get_vector(\"ui_left\", \"ui_right\", \"ui_up\", \"ui_down\")
		velocity = direction * SPEED		
	rotation_direction = Input.get_axis(\"rotate_ccw\", \"rotate_cw\")
	
func _physics_process(delta):
	get_input()
	if abs(rotation) < 0.80 or sign(rotation) != rotation_direction:
		rotation += rotation_direction * ROTATION_SPEED * delta
	if Input.is_action_just_pressed(\"action\"):
		$DashAnimationTimer.start(0.25)
		move_en = 0
	if Input.is_action_just_released(\"action\"):
		$DashAnimationTimer.stop()
		$AnimatedSprite2D.modulate = Color(1,1,1,1)
		dash_en = 1
		dash_direction = sign(rotation)
		$DashTimer.start(DASH_DURATION)
		$HornR.disabled = false
		$HornL.disabled = false
	move_and_slide()

func _on_timer_timeout():
	$AnimatedSprite2D.modulate *= Color(1.0, 1.0, 1.0, -1.0)

func _on_dash_timer_timeout() -> void:
	dash_en = 0
	move_en = 1
	$HornR.disabled = true
	$HornL.disabled = true
	$DashShockWave.play('default')

func _on_dash_shock_wave_animation_looped():
	$DashShockWave.stop()
"

